# Admin authentication
ADMIN_SECRET=your_secure_admin_password_here

# Database (if needed)
# DATABASE_URL=

# VIPPS Test Credentials (for payment processing)
VIPPS_CLIENT_ID=your_vipps_client_id
VIPPS_CLIENT_SECRET=your_vipps_client_secret
VIPPS_MERCHANT_SERIAL_NUMBER=your_merchant_serial_number
VIPPS_AUTH_TOKEN=your_vipps_auth_token_for_callbacks

# VIPPS URLs (update with your domain)
VIPPS_CALLBACK_URL=https://api.evendi.no/api/vipps/callback
VIPPS_REDIRECT_URL=https://app.evendi.no/subscription/return

# Frontend Environment
EXPO_PUBLIC_DOMAIN=app.evendi.no
EXPO_PUBLIC_API_URL=https://api.evendi.no
EXPO_PUBLIC_API_BASE=https://api.evendi.no

# YouTube Music Matcher (required for YouTube-backed recommendations + playlist export)
YOUTUBE_DATA_API_KEY=your_youtube_data_api_key
YOUTUBE_CLIENT_ID=your_google_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_google_oauth_client_secret
YOUTUBE_REDIRECT_URI=https://api.evendi.no/api/couple/music/youtube/callback
YOUTUBE_TOKEN_ENCRYPTION_KEY=your_32_byte_encryption_key
YOUTUBE_OAUTH_STATE_SECRET=your_oauth_state_secret

# Optional: Supabase (if using)
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Other environment variables
